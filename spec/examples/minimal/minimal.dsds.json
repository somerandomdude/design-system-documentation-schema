{
  "$schema": "../schema/dsds.bundled.schema.json",
  "dsdsVersion": "0.7.1",
  "systemInfo": {
    "systemName": "Minimal Example"
  },
  "entityGroups": [
    {
      "name": "Minimal Design System",
      "entities": [
        {
          "kind": "component",
          "identifier": "button",
          "name": "Button",
          "description": "A clickable button for triggering actions.",
          "metadata": {
            "status": "stable",
            "tags": [
              "action",
              "submit",
              "click",
              "CTA",
              "trigger",
              "call-to-action",
              "interactive"
            ]
          },
          "agentDocumentBlocks": [
            {
              "kind": "useCases",
              "purpose": "Trigger a user-initiated action within the current view without causing page navigation.",
              "items": [
                {
                  "description": "Use button for in-page actions; use link for navigation to a URL.",
                  "stance": "discouraged",
                  "alternative": {
                    "identifier": "link"
                  }
                },
                {
                  "description": "Use button when a visible text label is present; use icon-button for icon-only affordances.",
                  "stance": "discouraged",
                  "alternative": {
                    "identifier": "icon-button"
                  }
                }
              ]
            },
            {
              "kind": "guidelines",
              "items": [
                {
                  "guidance": "Do not use for navigating to a different page or URL.",
                  "level": "MUST_NOT"
                },
                {
                  "guidance": "Limit each surface to one primary-emphasis button.",
                  "level": "MUST"
                },
                {
                  "guidance": "Always provide an accessible label via visible text or aria-label.",
                  "level": "MUST"
                },
                {
                  "guidance": "Using a button to navigate to another page.",
                  "rationale": "Instead: Use a link element with href.",
                  "level": "MUST_NOT"
                },
                {
                  "guidance": "Placing multiple primary buttons on the same surface.",
                  "rationale": "Instead: Use one primary and one or more secondary or tertiary buttons.",
                  "level": "MUST_NOT"
                }
              ]
            }
          ]
        },
        {
          "kind": "token-group",
          "identifier": "tokens",
          "children": [
            {
              "kind": "token",
              "identifier": "color-text-primary",
              "tokenType": "color",
              "source": {
                "file": "tokens/color.tokens.json",
                "path": "color.text.primary"
              }
            },
            {
              "kind": "token",
              "identifier": "color-text-secondary",
              "tokenType": "color",
              "source": {
                "file": "tokens/color.tokens.json",
                "path": "color.text.secondary"
              }
            }
          ],
          "metadata": {
            "tags": [
              "token",
              "group",
              "palette",
              "scale",
              "family",
              "collection"
            ]
          },
          "agentDocumentBlocks": [
            {
              "kind": "sections",
              "items": [
                {
                  "title": "Intent",
                  "body": "Define and organize a set of related design tokens, providing shared defaults for type and category."
                }
              ]
            },
            {
              "kind": "guidelines",
              "items": [
                {
                  "guidance": "Do not reference base palette tokens directly in component code.",
                  "rationale": "Always reference semantic tokens that point to palette values.",
                  "level": "MUST_NOT"
                }
              ]
            }
          ]
        },
        {
          "kind": "token-group",
          "identifier": "color-text",
          "source": {
            "file": "tokens/color.tokens.json",
            "path": "color.text"
          },
          "children": [
            {
              "kind": "token",
              "identifier": "color-text-primary",
              "tokenType": "color",
              "source": {
                "file": "tokens/color.tokens.json",
                "path": "color.text.primary"
              }
            },
            {
              "kind": "token",
              "identifier": "color-text-secondary",
              "tokenType": "color",
              "source": {
                "file": "tokens/color.tokens.json",
                "path": "color.text.secondary"
              }
            }
          ],
          "metadata": {
            "tags": [
              "token",
              "group",
              "palette",
              "scale",
              "family",
              "collection"
            ]
          },
          "agentDocumentBlocks": [
            {
              "kind": "sections",
              "items": [
                {
                  "title": "Intent",
                  "body": "Define and organize a set of related design tokens, providing shared defaults for type and category."
                }
              ]
            },
            {
              "kind": "guidelines",
              "items": [
                {
                  "guidance": "Do not reference base palette tokens directly in component code.",
                  "rationale": "Always reference semantic tokens that point to palette values.",
                  "level": "MUST_NOT"
                }
              ]
            }
          ]
        },
        {
          "kind": "theme",
          "identifier": "dark",
          "name": "Dark Mode",
          "description": "Dark color mode for low-light environments.",
          "metadata": {
            "status": "stable",
            "tags": [
              "dark-mode",
              "color-mode",
              "night",
              "low-light",
              "theme",
              "override"
            ]
          },
          "overrides": [
            {
              "token": "color-text-primary",
              "description": "High-contrast text on dark surfaces."
            },
            {
              "token": "color-text-secondary",
              "description": "Muted text for secondary content in dark mode."
            }
          ],
          "agentDocumentBlocks": [
            {
              "kind": "useCases",
              "purpose": "Apply a dark color palette for low-light environments and user preference, maintaining WCAG AA contrast throughout.",
              "items": [
                {
                  "description": "Use dark for low-light comfort; use high-contrast for users with low vision requiring maximum contrast.",
                  "stance": "discouraged",
                  "alternative": {
                    "identifier": "high-contrast"
                  }
                }
              ]
            },
            {
              "kind": "guidelines",
              "items": [
                {
                  "guidance": "Always apply at the application root, not on individual components.",
                  "level": "MUST"
                },
                {
                  "guidance": "Do not mix dark-mode and light-mode semantic tokens on the same surface.",
                  "level": "MUST_NOT"
                },
                {
                  "guidance": "Applying dark theme only to part of a page while the rest remains light.",
                  "rationale": "Instead: Use inline theme switching for isolated components; apply the theme at the root for global coverage.",
                  "level": "MUST_NOT"
                }
              ]
            }
          ]
        },
        {
          "kind": "foundation",
          "identifier": "color",
          "name": "Color",
          "description": "The color system governing palette usage, semantic mapping, and accessibility.",
          "metadata": {
            "status": "stable",
            "tags": [
              "color",
              "palette",
              "semantic",
              "contrast",
              "accessibility",
              "background",
              "text",
              "theme"
            ]
          },
          "agentDocumentBlocks": [
            {
              "kind": "useCases",
              "purpose": "Document semantic color tokens and enforce their consistent, accessible application across surfaces, text, and interactive states.",
              "items": [
                {
                  "description": "Color governs palette and semantic role mapping; theme entities govern how the palette shifts per mode.",
                  "stance": "discouraged",
                  "alternative": {
                    "identifier": "dark"
                  }
                }
              ]
            },
            {
              "kind": "guidelines",
              "items": [
                {
                  "guidance": "Do not hard-code hex values; reference semantic color tokens instead.",
                  "level": "MUST_NOT"
                },
                {
                  "guidance": "Maintain WCAG AA contrast for text and interactive elements on every surface.",
                  "level": "MUST"
                }
              ]
            }
          ]
        },
        {
          "kind": "pattern",
          "identifier": "form-validation",
          "name": "Form Validation",
          "description": "Validates user input and communicates errors on form submission.",
          "metadata": {
            "status": "stable",
            "tags": [
              "error",
              "validation",
              "form",
              "feedback",
              "inline-error",
              "error-summary",
              "alert"
            ]
          },
          "agentDocumentBlocks": [
            {
              "kind": "useCases",
              "purpose": "Guide multi-component composition for surfacing, communicating, and resolving form validation errors.",
              "items": [
                {
                  "description": "Use error-messaging for validation and system errors; use empty-state for the absence of content.",
                  "stance": "discouraged",
                  "alternative": {
                    "identifier": "empty-state"
                  }
                },
                {
                  "description": "Use error-messaging for form validation flows; use alert for non-form system or status messages.",
                  "stance": "discouraged",
                  "alternative": {
                    "identifier": "alert"
                  }
                }
              ]
            },
            {
              "kind": "guidelines",
              "items": [
                {
                  "guidance": "Always include both an inline field error and a summary when multiple fields fail.",
                  "level": "MUST"
                },
                {
                  "guidance": "Do not use toast notifications as the sole error communication for form validation.",
                  "level": "MUST_NOT"
                },
                {
                  "guidance": "Showing errors only on submit without inline field feedback.",
                  "rationale": "Instead: Show inline errors on field blur and in a summary on submit.",
                  "level": "MUST_NOT"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
