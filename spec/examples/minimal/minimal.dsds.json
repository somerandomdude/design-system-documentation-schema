{
  "$schema": "../schema/dsds.bundled.schema.json",
  "dsdsVersion": "0.1",
  "metadata": {
    "systemName": "Minimal Example"
  },
  "documentation": [
    {
      "name": "Minimal Design System",
      "components": [
        {
          "kind": "component",
          "name": "button",
          "displayName": "Button",
          "description": "A clickable button for triggering actions.",
          "metadata": [
            {
              "kind": "status",
              "status": "stable"
            }
          ]
        }
      ],
      "tokenGroups": [
        {
          "kind": "token-group",
          "name": "tokens",
          "children": [
            {
              "kind": "token",
              "name": "color-text-primary",
              "tokenType": "color",
              "source": {
                "file": "tokens/color.tokens.json",
                "path": "color.text.primary"
              }
            },
            {
              "kind": "token",
              "name": "color-text-secondary",
              "tokenType": "color",
              "source": {
                "file": "tokens/color.tokens.json",
                "path": "color.text.secondary"
              }
            }
          ]
        },
        {
          "kind": "token-group",
          "name": "color-text",
          "source": {
            "file": "tokens/color.tokens.json",
            "path": "color.text"
          },
          "children": [
            {
              "kind": "token",
              "name": "color-text-primary",
              "tokenType": "color",
              "source": {
                "file": "tokens/color.tokens.json",
                "path": "color.text.primary"
              }
            },
            {
              "kind": "token",
              "name": "color-text-secondary",
              "tokenType": "color",
              "source": {
                "file": "tokens/color.tokens.json",
                "path": "color.text.secondary"
              }
            }
          ]
        }
      ],
      "themes": [
        {
          "kind": "theme",
          "name": "dark",
          "displayName": "Dark Mode",
          "description": "Dark color mode for low-light environments.",
          "metadata": [
            {
              "kind": "status",
              "status": "stable"
            }
          ],
          "overrides": [
            {
              "token": "color-text-primary",
              "description": "High-contrast text on dark surfaces."
            },
            {
              "token": "color-text-secondary",
              "description": "Muted text for secondary content in dark mode."
            }
          ]
        }
      ],
      "styles": [
        {
          "kind": "style",
          "name": "color",
          "displayName": "Color",
          "description": "The color system governing palette usage, semantic mapping, and accessibility.",
          "metadata": [
            {
              "kind": "status",
              "status": "stable"
            }
          ]
        }
      ],
      "patterns": [
        {
          "kind": "pattern",
          "name": "form-validation",
          "displayName": "Form Validation",
          "description": "Validates user input and communicates errors on form submission.",
          "metadata": [
            {
              "kind": "status",
              "status": "stable"
            }
          ]
        }
      ]
    }
  ]
}
