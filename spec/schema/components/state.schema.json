{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/state.schema.json",
  "title": "DSDS State Definitions",
  "description": "Definitions for documenting the interactive states a component can enter \u2014 hover, focus, active, disabled, loading, and other stateful configurations.",
  "$defs": {
    "state": {
      "type": "object",
      "description": "An interactive state a component can enter.",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Machine-readable state name."
        },
        "displayName": {
          "type": "string",
          "description": "Human-readable name."
        },
        "description": {
          "$ref": "../common/common.schema.json#/$defs/richText"
        },
        "tokens": {
          "type": "object",
          "description": "Token overrides for this state.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "preview": {
          "type": "array",
          "description": "Visual previews of this state.",
          "items": {
            "$ref": "../common/example.schema.json#/$defs/example"
          }
        },
        "useCases": {
          "$ref": "../common/usecase.schema.json#/$defs/useCases"
        }
      },
      "additionalProperties": false
    }
  }
}
