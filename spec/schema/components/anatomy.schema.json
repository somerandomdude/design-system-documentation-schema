{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/anatomy.schema.json",
  "title": "DSDS Anatomy Definitions",
  "description": "Definitions for documenting the visual structure of a component \u2014 its named sub-elements (parts) and their associated tokens.",
  "$defs": {
    "anatomyPart": {
      "type": "object",
      "description": "A named sub-element of a component's visual structure.",
      "required": [
        "name",
        "description",
        "required"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Machine-readable name of the part."
        },
        "displayName": {
          "type": "string",
          "description": "Human-readable name."
        },
        "description": {
          "$ref": "../common/common.schema.json#/$defs/richText"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this part is always present."
        },
        "tokens": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Names of design tokens applied to this part."
        }
      },
      "additionalProperties": false
    },
    "anatomy": {
      "type": "object",
      "description": "The visual structure of a component.",
      "required": [
        "parts"
      ],
      "properties": {
        "description": {
          "$ref": "../common/common.schema.json#/$defs/richText"
        },
        "parts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/anatomyPart"
          },
          "minItems": 1,
          "description": "The named sub-elements of the component."
        }
      },
      "additionalProperties": false
    }
  }
}
