{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/component.schema.json",
  "title": "DSDS Component Definitions",
  "description": "Definitions for the composite component document.",
  "$defs": {
    "componentDoc": {
      "type": "object",
      "description": "Documentation for a single reusable UI component.",
      "required": ["name", "displayName", "description", "status"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Machine-readable identifier (e.g., 'button', 'dialog', 'form-field', 'data-table')."
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Alternative names this component is known by across teams, tools, or legacy systems (e.g., ['btn', 'action-button', 'CTA']). Useful for search, migration mapping, and cross-referencing when different disciplines use different terminology for the same component."
        },
        "displayName": {
          "type": "string",
          "description": "Human-readable name."
        },
        "summary": {
          "type": "string",
          "description": "A one-line, plain-text summary. MUST NOT contain markup."
        },
        "description": {
          "$ref": "../common/common.schema.json#/$defs/richText"
        },
        "status": {
          "$ref": "../common/common.schema.json#/$defs/status"
        },
        "deprecationNotice": {
          "type": "string",
          "description": "Required when status is 'deprecated'."
        },
        "since": {
          "type": "string",
          "description": "The version in which this component was introduced."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Freeform keywords to relate guidelines across categories/disciplines (e.g., 'rtl', 'localization', 'validation')."
        },
        "category": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Component classification."
        },
        "preview": {
          "type": "array",
          "description": "Visual previews of the component.",
          "items": {
            "$ref": "../common/example.schema.json#/$defs/example"
          }
        },
        "anatomy": {
          "$ref": "anatomy.schema.json#/$defs/anatomy"
        },
        "api": {
          "oneOf": [
            {
              "$ref": "api.schema.json#/$defs/componentApi"
            },
            {
              "type": "object",
              "description": "A platform-keyed map of API objects.",
              "additionalProperties": {
                "$ref": "api.schema.json#/$defs/componentApi"
              }
            }
          ],
          "description": "The code-level API. Single API object or platform-keyed map."
        },
        "variants": {
          "type": "array",
          "description": "Named visual/behavioral configurations.",
          "items": {
            "$ref": "variant.schema.json#/$defs/variant"
          }
        },
        "states": {
          "type": "array",
          "description": "Interactive states.",
          "items": {
            "$ref": "state.schema.json#/$defs/state"
          }
        },
        "designSpecifications": {
          "$ref": "design-specifications.schema.json#/$defs/designSpecifications"
        },
        "useCases": {
          "$ref": "../common/usecase.schema.json#/$defs/useCases"
        },
        "guidelines": {
          "type": "array",
          "description": "Usage guidelines for the component. Each entry is a self-contained guideline. Use the `category` property on individual guidelines to group by concern (e.g., 'design', 'accessibility', 'content').",
          "items": {
            "$ref": "../common/guideline.schema.json#/$defs/guideline"
          }
        },
        "accessibility": {
          "$ref": "../common/accessibility.schema.json#/$defs/accessibilityObject"
        },
        "links": {
          "type": "array",
          "description": "External resource links and related artifact references.",
          "items": {
            "$ref": "../common/common.schema.json#/$defs/link"
          }
        },
        "$extensions": {
          "$ref": "../common/common.schema.json#/$defs/extensions"
        }
      },
      "if": {
        "properties": {
          "status": {
            "const": "deprecated"
          }
        }
      },
      "then": {
        "required": ["deprecationNotice"]
      },
      "additionalProperties": false
    }
  }
}
