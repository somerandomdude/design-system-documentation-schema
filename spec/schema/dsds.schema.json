{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/dsds.schema.json",
  "title": "Design System Documentation Standard (DSDS) v0.1",
  "description": "A standard, machine-readable format for design system documentation covering components, design tokens, styles, and patterns. This is the root schema; definitions are organized into directories: common/ (rich-text, metadata, status, link, extensions, example, guideline, usecase, accessibility, artifact-reference), components/ (component, anatomy, api, design-specifications, variant, state), tokens/ (token), style/ (style), and patterns/ (pattern).",
  "type": "object",
  "required": ["dsdsVersion", "documentType"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "URI reference to the DSDS JSON Schema for validation."
    },
    "dsdsVersion": {
      "type": "string",
      "const": "0.1",
      "description": "The version of the DSDS specification this document conforms to."
    },
    "documentType": {
      "type": "string",
      "enum": [
        "component",
        "token",
        "tokenGroup",
        "style",
        "pattern",
        "documentGroup"
      ],
      "description": "The type of artifact documented."
    },
    "metadata": {
      "$ref": "common/metadata.schema.json#/$defs/metadata"
    },
    "component": {
      "$ref": "components/component.schema.json#/$defs/componentDoc"
    },
    "token": {
      "$ref": "tokens/token.schema.json#/$defs/tokenDoc"
    },
    "tokenGroup": {
      "$ref": "tokens/token.schema.json#/$defs/tokenGroupDoc"
    },
    "style": {
      "$ref": "style/style.schema.json#/$defs/styleDoc"
    },
    "pattern": {
      "$ref": "patterns/pattern.schema.json#/$defs/patternDoc"
    },
    "documentGroup": {
      "$ref": "#/$defs/documents"
    },
    "$extensions": {
      "$ref": "common/extensions.schema.json#/$defs/extensions"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "documentType": {
            "const": "component"
          }
        }
      },
      "then": {
        "required": ["component"]
      }
    },
    {
      "if": {
        "properties": {
          "documentType": {
            "const": "token"
          }
        }
      },
      "then": {
        "required": ["token"]
      }
    },
    {
      "if": {
        "properties": {
          "documentType": {
            "const": "tokenGroup"
          }
        }
      },
      "then": {
        "required": ["tokenGroup"]
      }
    },
    {
      "if": {
        "properties": {
          "documentType": {
            "const": "style"
          }
        }
      },
      "then": {
        "required": ["style"]
      }
    },
    {
      "if": {
        "properties": {
          "documentType": {
            "const": "pattern"
          }
        }
      },
      "then": {
        "required": ["pattern"]
      }
    },
    {
      "if": {
        "properties": {
          "documentType": {
            "const": "documentGroup"
          }
        }
      },
      "then": {
        "required": ["documentGroup"]
      }
    }
  ],
  "$defs": {
    "documents": {
      "type": "object",
      "description": "A collection of multiple documentation artifacts.",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable name of the collection."
        },
        "description": {
          "$ref": "common/rich-text.schema.json#/$defs/richText"
        },
        "components": {
          "type": "array",
          "description": "Array of component documentation objects.",
          "items": {
            "$ref": "components/component.schema.json#/$defs/componentDoc"
          }
        },
        "tokens": {
          "type": "array",
          "description": "Array of token documentation objects.",
          "items": {
            "$ref": "tokens/token.schema.json#/$defs/tokenDoc"
          }
        },
        "tokenGroups": {
          "type": "array",
          "description": "Array of token group documentation objects.",
          "items": {
            "$ref": "tokens/token.schema.json#/$defs/tokenGroupDoc"
          }
        },
        "styles": {
          "type": "array",
          "description": "Array of style documentation objects.",
          "items": {
            "$ref": "style/style.schema.json#/$defs/styleDoc"
          }
        },
        "patterns": {
          "type": "array",
          "description": "Array of pattern documentation objects.",
          "items": {
            "$ref": "patterns/pattern.schema.json#/$defs/patternDoc"
          }
        }
      },
      "anyOf": [
        {
          "required": ["components"]
        },
        {
          "required": ["tokens"]
        },
        {
          "required": ["tokenGroups"]
        },
        {
          "required": ["styles"]
        },
        {
          "required": ["patterns"]
        }
      ],
      "additionalProperties": false
    }
  }
}
