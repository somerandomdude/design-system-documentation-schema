{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/tags.schema.json",
  "title": "DSDS Tags Metadata",
  "description": "Freeform keywords for categorization and search.",
  "$defs": {
    "tagsMetadata": {
      "type": "object",
      "required": ["kind", "items"],
      "properties": {
        "kind": { "type": "string", "const": "tags" },
        "items": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Keywords for categorization, search, and cross-referencing."
        }
      },
      "additionalProperties": false
    }
  }
}
