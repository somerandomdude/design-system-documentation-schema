{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/description.schema.json",
  "title": "DSDS Description Metadata",
  "description": "A rich-text description of the entity — what it is, what it does, and its role in the design system.",
  "$defs": {
    "descriptionMetadata": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": {
          "type": "string",
          "const": "description"
        },
        "value": {
          "$ref": "../common/rich-text.schema.json#/$defs/richText",
          "description": "A description of the entity. CommonMark supported."
        }
      },
      "additionalProperties": false
    }
  }
}
