{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/preview.schema.json",
  "title": "DSDS Preview Metadata",
  "description": "A visual or interactive preview — image, video, code snippet, or URL.",
  "$defs": {
    "previewMetadata": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "const": "preview" },
        "presentation": {
          "description": "The preview content.",
          "oneOf": [
            { "$ref": "../common/presentation.schema.json#/$defs/presentationImage" },
            { "$ref": "../common/presentation.schema.json#/$defs/presentationVideo" },
            { "$ref": "../common/presentation.schema.json#/$defs/presentationCode" },
            { "$ref": "../common/presentation.schema.json#/$defs/presentationUrl" }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
