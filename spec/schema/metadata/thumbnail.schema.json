{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/thumbnail.schema.json",
  "title": "DSDS Thumbnail Metadata",
  "description": "A visual thumbnail for compact display contexts.",
  "$defs": {
    "thumbnailMetadata": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "const": "thumbnail" },
        "image": { "$ref": "../common/presentation.schema.json#/$defs/presentationImage", "description": "The thumbnail image." }
      },
      "additionalProperties": false
    }
  }
}
