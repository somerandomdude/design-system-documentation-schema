{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/summary.schema.json",
  "title": "DSDS Summary Metadata",
  "description": "A one-line plain-text summary for compact display contexts.",
  "$defs": {
    "summaryMetadata": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "const": "summary" },
        "value": { "type": "string", "description": "One-line plain-text summary. MUST NOT contain markup." }
      },
      "additionalProperties": false
    }
  }
}
