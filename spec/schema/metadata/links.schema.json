{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/links.schema.json",
  "title": "DSDS Links Metadata",
  "description": "External resource links, internal artifact references, and entity relationships.",
  "$defs": {
    "linksMetadata": {
      "type": "object",
      "required": ["kind", "items"],
      "properties": {
        "kind": { "type": "string", "const": "links" },
        "items": { "type": "array", "items": { "$ref": "../common/link.schema.json#/$defs/link" }, "minItems": 1, "description": "Links to source code, design files, related entities, etc." }
      },
      "additionalProperties": false
    }
  }
}
