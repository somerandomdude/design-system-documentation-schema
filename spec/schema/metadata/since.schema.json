{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/since.schema.json",
  "title": "DSDS Since Metadata",
  "description": "The design system version in which this entity was introduced.",
  "$defs": {
    "sinceMetadata": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "const": "since" },
        "value": { "type": "string", "description": "Version string (e.g., '1.0.0', '2.3.0')." }
      },
      "additionalProperties": false
    }
  }
}
