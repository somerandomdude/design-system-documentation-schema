{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/category.schema.json",
  "title": "DSDS Category Metadata",
  "description": "Classification within the design system's taxonomy.",
  "$defs": {
    "categoryMetadata": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "const": "category" },
        "value": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$", "description": "Taxonomy category (e.g., 'action', 'navigation', 'feedback', 'base', 'semantic')." }
      },
      "additionalProperties": false
    }
  }
}
