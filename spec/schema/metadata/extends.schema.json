{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/extends.schema.json",
  "title": "DSDS Extends Metadata",
  "description": "Declares inheritance from a base entity in a parent system.",
  "$defs": {
    "extendsMetadata": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "const": "extends" },
        "extends": { "$ref": "../common/extends.schema.json#/$defs/entityExtends", "description": "The inheritance declaration." }
      },
      "additionalProperties": false
    }
  }
}
