{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.4/metadata/metadata.schema.json",
  "title": "DSDS Entity Metadata — Union",
  "description": "Defines the metadata union accepted by all entity types. Each entry is a typed metadata object with a `kind` discriminator.",
  "$defs": {
    "entityMetadata": {
      "oneOf": [
        { "$ref": "description.schema.json#/$defs/descriptionMetadata" },
        { "$ref": "status.schema.json#/$defs/statusMetadata" },
        { "$ref": "since.schema.json#/$defs/sinceMetadata" },
        { "$ref": "last-updated.schema.json#/$defs/lastUpdatedMetadata" },
        { "$ref": "tags.schema.json#/$defs/tagsMetadata" },
        { "$ref": "category.schema.json#/$defs/categoryMetadata" },
        { "$ref": "aliases.schema.json#/$defs/aliasesMetadata" },
        { "$ref": "summary.schema.json#/$defs/summaryMetadata" },
        { "$ref": "thumbnail.schema.json#/$defs/thumbnailMetadata" },
        { "$ref": "preview.schema.json#/$defs/previewMetadata" },
        { "$ref": "extends.schema.json#/$defs/extendsMetadata" },
        { "$ref": "links.schema.json#/$defs/linksMetadata" }
      ]
    },
    "entityMetadataArray": {
      "type": "array",
      "description": "An entity's metadata entries. Each metadata kind may appear at most once — an entity has a single description, status, summary, and so on. Zero entries of a kind is allowed; two or more of the same kind is not (it would leave no single source of truth for that field).",
      "items": { "$ref": "#/$defs/entityMetadata" },
      "allOf": [
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "description" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "status" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "since" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "last-updated" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "tags" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "category" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "aliases" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "summary" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "thumbnail" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "preview" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "extends" } } }, "minContains": 0, "maxContains": 1 },
        { "contains": { "required": ["kind"], "properties": { "kind": { "const": "links" } } }, "minContains": 0, "maxContains": 1 }
      ]
    }
  }
}
