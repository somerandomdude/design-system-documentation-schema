{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/status.schema.json",
  "title": "DSDS Status Metadata",
  "description": "Lifecycle status with optional per-platform readiness.",
  "$defs": {
    "statusMetadata": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "const": "status" },
        "status": { "$ref": "../common/status.schema.json#/$defs/statusValue" },
        "platformStatus": {
          "type": "object",
          "additionalProperties": {
            "$ref": "../common/status.schema.json#/$defs/platformStatus"
          }
        },
        "deprecationNotice": {
          "type": "string",
          "description": "Required when status is deprecated. MUST explain what to use instead."
        }
      },
      "additionalProperties": false
    }
  }
}
