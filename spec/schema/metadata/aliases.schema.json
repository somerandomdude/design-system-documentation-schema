{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://designsystemdocspec.org/v0.1/metadata/aliases.schema.json",
  "title": "DSDS Aliases Metadata",
  "description": "Alternative names for search, migration, and cross-referencing.",
  "$defs": {
    "aliasesMetadata": {
      "type": "object",
      "required": ["kind", "items"],
      "properties": {
        "kind": { "type": "string", "const": "aliases" },
        "items": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Alternative names across teams, tools, or legacy systems."
        }
      },
      "additionalProperties": false
    }
  }
}
