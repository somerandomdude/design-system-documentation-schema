{
  "name": "design-system-documentation-schema",
  "version": "0.14.0",
  "description": "A standard, machine-readable format for design system documentation.",
  "contributors": [
    {
      "name": "Afyia Smith",
      "url": "https://afyiasmith.co/"
    }
  ],
  "scripts": {
    "sync-examples": "node scripts/sync-examples.js",
    "check-examples": "node scripts/sync-examples.js --check",
    "validate": "node scripts/validate.js",
    "bundle": "node scripts/bundle.js",
    "build": "node scripts/build-site.js",
    "visualize": "node scripts/visualize.js",
    "readability": "node scripts/readability-audit.mjs",
    "bump-version": "node scripts/bump-version.js",
    "prebuild": "npm run sync-examples && npm run bundle",
    "prevalidate": "npm run sync-examples && npm run bundle",
    "check-docs": "node scripts/check-doc-coverage.mjs",
    "lint:tokens": "node scripts/lint-token-refs.mjs",
    "postvalidate": "npm run check-docs && npm run lint:tokens && node scripts/extract-normative.mjs --check",
    "lint:docs": "node scripts/lint-docs.js",
    "normative": "node scripts/extract-normative.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somerandomdude/design-system-documentation-schema.git"
  },
  "keywords": [
    "design-system",
    "documentation",
    "json-schema",
    "dsds",
    "components",
    "tokens",
    "patterns",
    "styles"
  ],
  "author": "PJ Onori",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/somerandomdude/design-system-documentation-schema/issues"
  },
  "homepage": "https://github.com/somerandomdude/design-system-documentation-schema#readme",
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "js-yaml": "^4.2.0",
    "remark-gfm": "^4.0.1"
  }
}
