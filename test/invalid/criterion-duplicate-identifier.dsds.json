{
  "dsdsVersion": "0.15.1",
  "entity": {
    "kind": "component",
    "identifier": "button",
    "name": "Button",
    "documentBlocks": [
      {
        "kind": "guidelines",
        "items": [
          {
            "guidance": "Always provide an accessible label.",
            "rationale": "Unnamed controls are unusable with screen readers.",
            "level": "must",
            "criteria": [
              {
                "identifier": "label-present",
                "statement": "Every button exposes an accessible name."
              }
            ]
          },
          {
            "guidance": "Limit each surface to one primary button.",
            "rationale": "Multiple primary actions dilute hierarchy.",
            "level": "should",
            "criteria": [
              {
                "identifier": "label-present",
                "statement": "At most one primary button per surface."
              }
            ]
          }
        ]
      }
    ]
  }
}
